# Postgres (sim-worker + api + db package read this)
DATABASE_URL=postgres://colony:colony@localhost:5440/colony

# Redis (pubsub + BullMQ)
REDIS_URL=redis://localhost:6390

# LLM (Vercel AI Gateway or direct provider).
# Leave empty to run in deterministic-fallback mode (no LLM calls).
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=

# Models routed through AI Gateway
LLM_MODEL_DEFAULT=openai/gpt-4o-mini
LLM_MODEL_ESCALATION=openai/gpt-4o
LLM_EMBEDDING_MODEL=openai/text-embedding-3-small

# World tuning
WORLD_SPEED=1
WORLD_TICK_MS=1000
SIM_AGENT_COUNT=30
LLM_HOURLY_USD_CAP=5

# Public API
API_PORT=4001
API_HOST=0.0.0.0

# Web (Next.js)
NEXT_PUBLIC_API_BASE=http://localhost:4001
NEXT_PUBLIC_WS_URL=ws://localhost:4001/v1/events/stream
