{
  "name": "thecolony",
  "version": "0.0.0",
  "private": true,
  "description": "A browser-based persistent civilization where every citizen is an AI agent trying to survive.",
  "author": "hello@virajbhartiya.com",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:migrate": "pnpm --filter @thecolony/db migrate",
    "db:seed": "pnpm --filter @thecolony/sim-worker seed",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "docker:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "@types/node": "^22.10.5"
  }
}
